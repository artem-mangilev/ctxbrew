{
  "name": "ctxbrew",
  "version": "0.1.0",
  "description": "CLI for packaging docs/source into versioned context bundles for AI agents.",
  "type": "module",
  "bin": {
    "ctxb": "./bin/ctxb.js"
  },
  "scripts": {
    "dev": "bun run ./src/bin/ctxb.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun run scripts/build.ts"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.3.6"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "ai",
    "agent",
    "documentation",
    "context",
    "bun",
    "javascript"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "semver": "^7.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/bun": "latest",
    "@types/semver": "^7.5.8",
    "semantic-release": "^25.0.3",
    "typescript": "^5.6.3"
  }
}
