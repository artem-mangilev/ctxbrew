{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "CTXBREW_RELEASE_VERSION=${nextRelease.version} bun run scripts/sync-optional-deps.ts && CTXBREW_RELEASE_VERSION=${nextRelease.version} bun run scripts/publish-platforms.ts"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": true,
        "pkgRoot": "."
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "dist/ctxbrew-darwin-arm64", "label": "ctxbrew-darwin-arm64" },
          { "path": "dist/ctxbrew-darwin-x64", "label": "ctxbrew-darwin-x64" },
          { "path": "dist/ctxbrew-linux-x64", "label": "ctxbrew-linux-x64" },
          { "path": "dist/ctxbrew-linux-arm64", "label": "ctxbrew-linux-arm64" },
          { "path": "dist/ctxbrew-windows-x64.exe", "label": "ctxbrew-windows-x64.exe" }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "package.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
