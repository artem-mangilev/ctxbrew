{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": true,
        "pkgRoot": "."
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "dist/ctxb-darwin-arm64", "label": "ctxb-darwin-arm64" },
          { "path": "dist/ctxb-darwin-x64", "label": "ctxb-darwin-x64" },
          { "path": "dist/ctxb-linux-x64", "label": "ctxb-linux-x64" },
          { "path": "dist/ctxb-linux-arm64", "label": "ctxb-linux-arm64" },
          { "path": "dist/ctxb-windows-x64.exe", "label": "ctxb-windows-x64.exe" }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "package.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
